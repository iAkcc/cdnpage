# ===== Copia este archivo a .env (local) y a Variables de Entorno en Netlify =====
# NUNCA incluyas .env en git. Ya está en .gitignore

# ---- JWT / Sesiones ----
# Genera con: openssl rand -base64 48
SESSION_SECRET=

# Dominio donde se sirve el panel (en Netlify)
PUBLIC_URL=https://tu-sitio.netlify.app

# ---- Magic links por email (elige un proveedor) ----
# Opción A: Resend
RESEND_API_KEY=
EMAIL_FROM=no-reply@tudominio.com

# Opción B: Postmark
POSTMARK_SERVER_TOKEN=
# EMAIL_FROM se reutiliza

# ---- Cloudflare R2 (compatible S3) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=cdn-public
R2_BUCKET_PRIVATE=cdn-private
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# Dominio público mapeado al bucket public (ej: https://cdn.tudominio.com)
R2_PUBLIC_BASE_URL=https://cdn.tudominio.com
# TTL en segundos de las URLs firmadas para archivos privados
R2_SIGNED_URL_TTL=900

# ---- Netlify Blobs (metadatos) ----
# Se inicializan automáticamente en runtime de Netlify Functions
# NETLIFY_BLOBS_CONTEXT=  (inyectado por Netlify)

# ---- Admin bootstrap ----
# Email inicial del administrador (para el primer magic link)
ADMIN_EMAIL=admin@tudominio.com

# ---- App ----
VITE_API_BASE=/api
